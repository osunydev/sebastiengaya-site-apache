RedirectMatch permanent "^/accessibilite(/?)$" "/fr/accessibilite/"
RedirectMatch permanent "^/test\-redirection\-sans\-slash$" "https://google.com"
RedirectMatch permanent "^/plan\-du\-site(/?)$" "/fr/plan-du-site/"
RedirectMatch permanent "^/organisations(/?)$" "/fr/organisations/"
RedirectMatch permanent "^/actualites/2025\-02\-04\-apache\-http\-server\-2\-4\-66\-released(/?)$" "/fr/actualites/2025-02-04-apache-http-server-2-4-66-released/"
